{
  "manifest_version": 3,
  "name": "NotebookLM Organizer",
  "version": "1.0.0",
  "description": "Organiza tus cuadernos de NotebookLM con hashtags en los nombres",
  "permissions": ["sidePanel", "tabs", "storage"],
  "host_permissions": ["https://notebooklm.google.com/*"],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://notebooklm.google.com/*"],
      "js": [
        "shared/constants.js",
        "shared/messages.js",
        "shared/parser.js",
        "shared/tree-builder.js",
        "content/scraper.js",
        "content/observer.js",
        "content/content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "action": {
    "default_title": "NotebookLM Organizer",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
